APP_NAME="AI Shorts Automation System"
ENVIRONMENT=local
LOG_LEVEL=INFO

DATABASE_URL=sqlite+aiosqlite:///./database/shorts.db
SQL_ECHO=false

SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=30
MAX_CLIPS_PER_VIDEO=3
MIN_CLIP_SECONDS=18
MAX_CLIP_SECONDS=58
VIRAL_SCORE_THRESHOLD=0.72
ALLOW_HEURISTIC_CLIP_FALLBACK=true

FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe
YTDLP_FORMAT=bv*+ba/b
YTDLP_MERGE_OUTPUT_FORMAT=mp4

WHISPER_CPP_BINARY=whisper-cpp
WHISPER_MODEL_PATH=models/ggml-tiny.en.bin
WHISPER_LANGUAGE=auto
WHISPER_THREADS=4

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=120

SHORTS_WIDTH=1080
SHORTS_HEIGHT=1920
CRF=23
VIDEO_PRESET=veryfast
AUDIO_BITRATE=160k

YOUTUBE_UPLOAD_ENABLED=false
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json
YOUTUBE_TOKEN_FILE=youtube_token.json
YOUTUBE_PRIVACY_STATUS=private

ANALYTICS_REFRESH_HOURS=6
ANALYTICS_SNAPSHOT_HOURS=1,6,24,72,168
ANALYTICS_MIN_REFRESH_MINUTES=30
JOB_WORKER_INTERVAL_MINUTES=1
JOB_MAX_ATTEMPTS=3
CLEANUP_ENABLED=true
STORAGE_CLEANUP_MODE=mark_only
SOURCE_VIDEO_RETENTION_DAYS=30
AUDIO_RETENTION_DAYS=14
TRANSCRIPT_RETENTION_DAYS=180
PREVIEW_RETENTION_DAYS=14
RENDERED_CLIP_RETENTION_DAYS=365
TEMP_RETENTION_DAYS=3
UPLOAD_MIN_ORIGINALITY_SCORE=60
UPLOAD_MIN_HOOK_QUALITY=55
UPLOAD_MIN_PACING_SCORE=50
UPLOAD_MAX_DEAD_ZONE_RISK=65
REQUEST_TIMEOUT_SECONDS=30
RETRY_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=1.5
